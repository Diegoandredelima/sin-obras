# ============================================
# SIN-Obras — Variáveis de Ambiente
# ============================================
# Copie este arquivo para .env e preencha os valores.

# --- Banco de Dados ---
POSTGRES_USER=sinobras
POSTGRES_PASSWORD=sinobras_dev_2026
POSTGRES_DB=sinobras
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://sinobras:sinobras_dev_2026@postgres:5432/sinobras

# --- Backend ---
SECRET_KEY=super-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
BACKEND_CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# --- MinIO (S3 Local) ---
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123
MINIO_ENDPOINT=minio:9000
MINIO_BUCKET=sinobras-fotos

# --- E-mail transacional (RF10) ---
# Deixe EMAIL_ENABLED=false em dev (notificações só no sistema, sem envio real).
EMAIL_ENABLED=false
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_USE_TLS=true
EMAIL_FROM=nao-responder@sin.rn.gov.br
EMAIL_FROM_NAME=SIN-Obras

# --- Frontend ---
VITE_API_URL=http://localhost:8000/api
