#!/usr/bin/env bash
# =============================================================================
# SIN-Obras — hook de pre-push (validação local, substitui o CI não usado)
# =============================================================================
# Roda scripts/validate.sh (lint + testes + typecheck + build) antes de cada
# push e aborta se algo falhar. Não depende de `make`.
#
# Ative uma vez com:  git config core.hooksPath .githooks   (ou: make hooks)
# Pule pontualmente:  git push --no-verify
# =============================================================================
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

echo "🔎 pre-push: rodando scripts/validate.sh (use 'git push --no-verify' para pular)..."

if ! bash "$ROOT/scripts/validate.sh"; then
  echo "❌ Validação falhou — push abortado. Corrija ou use 'git push --no-verify'."
  exit 1
fi

echo "✅ pre-push: validação OK."
